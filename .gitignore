# Dependencies — all levels
node_modules/
server/node_modules/
client/node_modules/

# Build output
client/dist/

# SQLite database — never commit the DB file
server/data/
*.sqlite
*.sqlite3
*.db

# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# OS & editor clutter
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp
*.swo

# PM2 log output — keep the logs/ dir but not the content
logs/*.log
logs/*.log.*

# npm / yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
