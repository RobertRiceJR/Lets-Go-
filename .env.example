# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Port the Express server listens on.
# Railway sets this automatically — you do NOT need to set it there.
PORT=3001

# Set to "production" on Railway (Railway sets this automatically).
NODE_ENV=development

# Absolute path to the SQLite database file.
# In development: leave blank to use the default (server/data/db.sqlite).
# On Railway: set to /data/db.sqlite and mount a persistent volume at /data.
DB_PATH=

# Your Railway public domain (no https://, no trailing slash).
# Example: lets-go-production.up.railway.app
# Leave blank in development.
RAILWAY_PUBLIC_DOMAIN=
